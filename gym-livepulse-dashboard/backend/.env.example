PORT=5000

# Local MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/gym_livepulse

# MongoDB Atlas — encode special characters in the password in the URI:
#   #  →  %23     @  →  %40     /  →  %2F     :  →  %3A
# Example:
# MONGODB_URI=mongodb+srv://USER:ENCODED_PASSWORD@cluster0.xxxxx.mongodb.net/gym_livepulse?retryWrites=true&w=majority&appName=Cluster0

MONGODB_URI=mongodb://127.0.0.1:27017/gym_livepulse
AUTO_SEED_IF_EMPTY=true
